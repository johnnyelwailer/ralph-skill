{
  "name": "aloop-cli",
  "version": "1.0.0",
  "description": "Aloop CLI for dashboard and project orchestration",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "aloop": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run clean && npm run build:dashboard && npm run build:server && npm run build:shebang",
    "build:dashboard": "npm --prefix dashboard run build -- --outDir ../dist/dashboard --emptyOutDir",
    "build:server": "esbuild src/index.ts --bundle --platform=node --format=esm \"--banner:js=import { createRequire } from 'module'; const require = createRequire(import.meta.url);\" --outfile=dist/index.js",
    "build:shebang": "node -e \"const f='dist/index.js',c=require('node:fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('node:fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "dev": "tsx src/index.ts",
    "test": "tsx --test src/**/*.test.ts && node --test aloop.test.mjs",
    "test-install": "npm run build && node scripts/test-install.mjs",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.20.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
